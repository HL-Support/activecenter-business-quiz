{
  "name": "business-leads-quiz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "verify": "node scripts/verify.js",
    "guard:deploy": "node scripts/guard-production-deploy.js",
    "deploy:prod": "npm run verify && npm run build && npm run guard:deploy && npx vercel deploy --prod --yes",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json}\"",
    "check": "npm run lint && npm run format"
  },
  "dependencies": {
    "jsonwebtoken": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
